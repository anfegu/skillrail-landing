---
/**
 * Solution Section - Enterprise-Grade Precision
 * 
 * FOLLOWS BRAND_IDENTITY_SYSTEM.MD:
 * - "Precision Through Restraint" philosophy.
 * - Lighter background (Slate-100) to alternate with dark sections.
 * - Indigo borders and Emerald accents.
 * - No glassmorphism, no emojis.
 */

const solutionHeadline = "SkillRail Protocol";
const solutionSubheadline = "The Trustless Standard";
const solutionDescription = "A Solana-native smart infrastructure protocol designed for the autonomous coordination, execution, and settlement of digital work and agent-driven workflows.";
const solutionStatus = import.meta.env.PUBLIC_SOLUTION_STATUS || "DEVELOPMENT_ACTIVE";

// Status Color Logic
const solutionStatusColors = {
  DEVELOPMENT_ACTIVE: "#94A3B8",        // Slate - Foundational Building
  PHASE_01_INITIALIZATION: "#6366F1",   // Indigo - Systematic Setup
  PHASE_02_VALIDATION: "#F59E0B",       // Amber - Testing/Verification
  SETTLEMENT_READY: "#10B981",          // Emerald - Completed/Finality
};

const currentSolutionColor = solutionStatusColors[solutionStatus as keyof typeof solutionStatusColors] || "#94A3B8";

const solutions = [
  { 
    title: "Atomic Escrow", 
    description: "Programmable logic accounts hold assets with immutable rules. Safety is guaranteed by distributed network consensus. (Solana runtime)",
    label: "SYS_ESCROW_V2",
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`
  },
  { 
    title: "Deterministic Pay", 
    description: "Instant, programmable settlement triggered by verifiable work proofs. Zero human-in-the-loop latency.",
    label: "AUTO_SETTLE_L1",
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`
  },
  { 
    title: "Agentic Logic", 
    description: "Optimized for the machine-to-machine economy. Native support for autonomous agent participation.",
    label: "AGENT_RUNTIME",
    svg: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2zM9 16v-4m3 4V10m3 6v-2"/></svg>`
  },
];
---

<section id="solution" class="sr-solution-precision">
  <!-- Subtle Background -->
  <div class="sr-solution-precision__bg">
    <div class="grid-subtle"></div>
  </div>
  
  <div class="container relative-z">
    <!-- Header -->
    <div class="section-header">
      <div class="header-badge">
        <span class="badge-text">PROTO_SOL_01</span>
      </div>
      <h2 class="headline">
        <span class="h-main">{solutionHeadline}</span>
        <span class="h-sub">{solutionSubheadline}</span>
      </h2>
      <p class="description">{solutionDescription}</p>
    </div>
    
    <!-- Solution Matrix -->
    <div class="solution-grid">
      {solutions.map((solution) => (
        <div class="solution-panel">
          <div class="panel-header">
            <div class="panel-icon" set:html={solution.svg} />
            <div class="panel-meta">{solution.label}</div>
          </div>
          
          <h3 class="panel-title">{solution.title}</h3>
          <p class="panel-text">{solution.description}</p>
          
          <div class="panel-footer">
            <span class="status-chip" style={`color: ${currentSolutionColor}`}>{solutionStatus}</span>
            <div class="status-indicator dev-mode" style={`background: ${currentSolutionColor}; box-shadow: 0 0 8px ${currentSolutionColor}`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .sr-solution-precision {
    position: relative;
    padding: 6rem 0;
    background-color: #F8FAFC; /* Neutral Light / Slate-100 */
    overflow: hidden;
  }

  .relative-z { position: relative; z-index: 10; }

  .sr-solution-precision__bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    opacity: 0.5;
  }

  .grid-subtle {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: linear-gradient(#E2E8F0 1px, transparent 1px), linear-gradient(90deg, #E2E8F0 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at center, black, transparent);
  }

  /* ============================================
     HEADER
     ============================================ */

  .section-header { text-align: center; margin-bottom: 4rem; }

  .header-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background: #EEF2FF;
    border: 1px solid #E0E7FF;
    border-radius: 4px;
    margin-bottom: 2rem;
  }

  .badge-text {
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: #6366F1;
  }

  .headline { margin-bottom: 1.5rem; }
  .h-main { display: block; font-size: 3.5rem; font-weight: 900; color: #0F172A; line-height: 1.1; letter-spacing: -0.02em; }
  .h-sub { display: block; font-size: 1.75rem; font-weight: 600; color: #64748B; margin-top: 0.5rem; }

  .description { font-size: 1.25rem; color: #475569; max-width: 650px; margin: 0 auto; line-height: 1.6; }

  /* ============================================
     SOLUTION GRID
     ============================================ */

  .solution-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }

  .solution-panel {
    background: white;
    border: 1px solid #E2E8F0;
    padding: 1.5rem 2rem; /* Compacted from 3rem */
    border-radius: 4px;
    transition: all 200ms ease-out;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .solution-panel:hover {
    border-color: #6366F1;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.08);
  }

  .panel-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem; /* Compacted from 2.5rem */
  }

  .panel-icon { color: #6366F1; }
  .panel-meta { font-family: var(--font-family-mono); font-size: 0.6rem; color: #94A3B8; font-weight: 700; }

  .panel-title { font-size: 1.5rem; font-weight: 800; color: #0F172A; margin-bottom: 1rem; }
  .panel-text { font-size: 0.95rem; color: #64748B; line-height: 1.6; margin-bottom: 2rem; flex: 1; }

  .panel-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.5rem; /* Compacted from 2rem */
    border-top: 1px solid #F1F5F9;
  }

  .status-chip { font-family: var(--font-family-mono); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.05em; }
  .status-indicator { width: 8px; height: 8px; border-radius: 50%; }
  .status-indicator.dev-mode { animation: pulse-warning 2s infinite; }

  @keyframes pulse-warning {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
    100% { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 768px) {
    .sr-solution-precision {
      padding: 3rem 0;
    }
    .h-main {
      font-size: 2.25rem;
    }
    .h-sub {
      font-size: 1.25rem;
    }
    .description {
      font-size: 1rem;
      margin-bottom: 2rem;
    }
    
    .solution-grid {
      grid-template-columns: 1fr !important;
      gap: 0.75rem !important;
    }
    
    .solution-panel {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      gap: 1.25rem !important;
      padding: 1rem !important;
      border-radius: 4px;
    }
    
    .panel-header {
      margin-bottom: 0 !important;
      flex-shrink: 0;
    }

    .panel-icon {
      padding: 0.4rem;
      background: #EEF2FF;
      border-radius: 4px;
    }

    .panel-icon svg {
      width: 18px;
      height: 18px;
    }

    .panel-meta, .panel-footer {
      display: none !important;
    }
    
    .panel-title {
      font-size: 1.15rem !important;
      margin-bottom: 0 !important;
      font-weight: 800;
      min-width: 110px;
    }
    
    .panel-text {
      font-size: 0.85rem !important;
      margin-bottom: 0 !important;
      line-height: 1.3 !important;
    }
  }
</style>
