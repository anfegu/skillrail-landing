---
/**
 * Footer - Compact & Persistent Design
 * Uses Environment Variables for professional link management.
 */

// Environment Variables with Fallbacks
const solanaExplorerUrl = import.meta.env.PUBLIC_SOLANA_EXPLORER_URL || "https://explorer.solana.com";
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL || "https://github.com";
const xUrl = import.meta.env.PUBLIC_X_URL || "#";
const discordUrl = import.meta.env.PUBLIC_DISCORD_URL || "#";
const docsPath = import.meta.env.PUBLIC_DOCS_URL || "/docs";
---

<footer class="sr-footer-compact">
  <div class="container">
    <div class="footer-content">
      <!-- Brand & Copyright -->
      <div class="footer-brand">
        <span class="brand-logo">SR</span>
        <span class="brand-copy">&copy; 2026 SkillRail.</span>
      </div>

      <!-- Navigation -->
      <nav class="footer-nav">
        <ul class="footer-links">
          <li><a href={solanaExplorerUrl} target="_blank" rel="noopener noreferrer" class="f-link">SOLANA_EXPLORER</a></li>
          <li><a href={docsPath} class="f-link">DOCS</a></li>
          <li><a href={githubUrl} target="_blank" rel="noopener noreferrer" class="f-link">GITHUB</a></li>
          <li><a href={xUrl} target="_blank" rel="noopener noreferrer" class="f-link">X</a></li>
          <li><a href={discordUrl} target="_blank" rel="noopener noreferrer" class="f-link">DISCORD</a></li>
        </ul>
      </nav>

      <!-- Status Indicator -->
      <div class="footer-status">
        <span class="status-label">SYS_STATUS:</span>
        <span class="status-value">OPERATIONAL</span>
        <div class="status-pulse"></div>
      </div>
    </div>
  </div>
</footer>

<style>
  .sr-footer-compact {
    position: sticky;
    bottom: 0;
    background-color: #020617;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 1.25rem 0;
    margin-top: -1px;
    z-index: 1000;
    backdrop-filter: blur(10px);
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  /* ============================================
     BRAND
     ============================================ */

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand-logo {
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    font-weight: 800;
    background: #6366F1;
    color: white;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
  }

  .brand-copy {
    font-size: 0.75rem;
    color: #475569;
    font-weight: 500;
  }

  /* ============================================
     NAVIGATION
     ============================================ */

  .footer-links {
    list-style: none;
    display: flex;
    gap: 2rem;
    padding: 0;
    margin: 0;
  }

  .f-link {
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: #94A3B8;
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color 0.2s ease;
  }

  .f-link:hover {
    color: #6366F1;
  }

  /* ============================================
     STATUS
     ============================================ */

  .footer-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .status-label {
    font-family: var(--font-family-mono);
    font-size: 0.6rem;
    color: #334155;
    font-weight: 800;
  }

  .status-value {
    font-family: var(--font-family-mono);
    font-size: 0.65rem;
    color: #10B981;
    font-weight: 700;
  }

  .status-pulse {
    width: 6px;
    height: 6px;
    background: #10B981;
    border-radius: 50%;
    box-shadow: 0 0 8px #10B981;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.5); opacity: 0.5; }
    100% { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 768px) {
    .sr-footer-compact {
      padding: 0.3rem 0;
      height: auto;
    }
    
    .footer-content {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      align-items: center;
      gap: 0.2rem;
    }

    .footer-brand {
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }

    .brand-logo {
      font-size: 0.7rem;
      padding: 0.15rem 0.3rem;
    }

    .brand-copy {
      display: inline-block;
      font-size: 0.75rem;
      color: #94A3B8;
    }

    .footer-nav {
      width: 100%;
      order: 3;
      padding-top: 0.25rem;
      border-top: 1px solid rgba(255, 255, 255, 0.03);
    }

    .footer-links {
      display: flex;
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.2rem 1rem;
    }

    .f-link {
      font-size: 0.7rem;
      letter-spacing: 0;
    }

    .footer-status {
      display: flex;
      align-items: center;
      gap: 0.3rem;
    }

    .status-label {
      display: inline-block;
      font-size: 0.6rem;
    }

    .status-value {
      font-size: 0.65rem;
    }

    .status-pulse {
      width: 5px;
      height: 5px;
    }

    .sr-footer-compact .container {
      padding: 0 1rem;
      max-width: none;
    }
  }
</style>
