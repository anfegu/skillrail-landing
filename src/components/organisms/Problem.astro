---
/**
 * Problem Section - Enterprise-Grade Redesign
 * 
 * DESIGN PHILOSOPHY: "Dual-Sided Risk Visualization"
 * - Two-column layout with center divider
 * - Amber borders (caution, risk)
 * - Monospace icons (technical, not decorative)
 * - Center divider: Indigo line (protocol mediates)
 */

const problemHeadline = "The Trust Gap in Digital Work";
const problemDescription = "Both requesters and providers face significant risk in asynchronous work. Traditional solutions are informal, fragmented, and poorly suited for automated workflows.";
---

<section class="sr-problem">
  <div class="container">
    <h2 class="sr-problem__headline">
      {problemHeadline}
    </h2>
    <p class="sr-problem__description">
      {problemDescription}
    </p>
    
    <div class="sr-problem__grid">
      <div class="sr-problem__card">
        <div class="sr-problem__icon">⚠</div>
        <h3 class="sr-problem__card-title">Requester Risk</h3>
        <p class="sr-problem__card-text">Pay for work, but never receive delivery or a substandard outcome with little recourse.</p>
      </div>
      
      <div class="sr-problem__divider"></div>
      
      <div class="sr-problem__card">
        <div class="sr-problem__icon">⚠</div>
        <h3 class="sr-problem__card-title">Provider Risk</h3>
        <p class="sr-problem__card-text">Deliver work, but never receive payment or face delays and disputes without clear settlement paths.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-problem {
    padding: var(--section-padding-vertical-desktop) var(--section-padding-horizontal);
    background-color: var(--color-bg-secondary);
  }
  
  .sr-problem__headline {
    font-size: var(--font-size-h2);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-navy);
    text-align: center;
    margin-bottom: var(--space-lg);
  }
  
  .sr-problem__description {
    font-size: 1.125rem;
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }
  
  .sr-problem__grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
    max-width: 900px;
    margin: 0 auto;
  }
  
  .sr-problem__card {
    position: relative;
    padding: var(--card-padding);
    background-color: var(--color-bg-primary);
    border: 2px solid var(--color-amber);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }
  
  .sr-problem__card:hover {
    box-shadow: 0 10px 30px rgba(245, 158, 11, 0.15);
    transform: translateY(-2px);
  }
  
  .sr-problem__icon {
    font-size: 2rem;
    font-family: var(--font-family-mono);
    color: var(--color-amber);
    margin-bottom: var(--space-md);
    font-weight: var(--font-weight-bold);
  }
  
  .sr-problem__card-title {
    font-size: var(--font-size-h4);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-heading);
    letter-spacing: var(--letter-spacing-heading);
    color: var(--color-navy);
    margin-bottom: var(--space-md);
  }
  
  .sr-problem__card-text {
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }
  
  .sr-problem__divider {
    width: 2px;
    background: linear-gradient(180deg, transparent 0%, var(--color-indigo) 50%, transparent 100%);
    margin: 0 var(--space-lg);
  }
  
  @media (max-width: 768px) {
    .sr-problem {
      padding: var(--section-padding-vertical-tablet) var(--section-padding-horizontal-mobile);
    }
    
    .sr-problem__headline {
      font-size: 1.875rem;
      margin-bottom: var(--space-md);
    }
    
    .sr-problem__description {
      font-size: 1rem;
      margin-bottom: var(--space-2xl);
    }
    
    .sr-problem__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    
    .sr-problem__divider {
      display: none;
    }
  }
  
  @media (prefers-reduced-motion: reduce) {
    .sr-problem__card {
      transition: none;
    }
    
    .sr-problem__card:hover {
      transform: none;
    }
  }
</style>
