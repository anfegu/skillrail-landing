---
/**
 * Problem Section - Symmetrical Precision
 * 
 * DESIGN PHILOSOPHY: "Balanced Duality"
 * - MAINTAINED: Original background system and text contents.
 * - INNOVATION: Symmetrical data-panels with a refined central logic-line.
 * - OPTIMIZATION: Ultra-compact vertical footprint.
 */

const problemHeadline = "The Critical Trust Gap";
const problemDescription = "Digital work suffers from fundamental trust issues that cost billions in failed transactions every year.";
---

<section id="problem" class="sr-problem-refined">
  <!-- Dramatic Background (MAINTAINED EXACTLY) -->
  <div class="sr-problem-refined__bg">
    <div class="bg-gradient"></div>
    <div class="bg-pattern"></div>
    <div class="warning-particles">
      <div class="warning-particle particle-1"></div>
      <div class="warning-particle particle-2"></div>
      <div class="warning-particle particle-3"></div>
      <div class="warning-particle particle-4"></div>
    </div>
  </div>
  
  <div class="container relative-z">
    <!-- Header -->
    <div class="section-header">
      <div class="tech-badge">RISK_ANALYSIS_v4.2</div>
      <h2 class="headline">{problemHeadline}</h2>
      <p class="description">{problemDescription}</p>
    </div>
    
    <div class="risk-matrix">
      <!-- Requester Side -->
      <div class="risk-module requester">
        <div class="module-header">
          <div class="module-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22M17 5H9.5a4.5 4.5 0 1 0 0 9h5a4.5 4.5 0 1 1 0 9H6"/></svg>
          </div>
          <div class="module-info">
            <span class="module-id">SOURCE_A</span>
            <h3 class="module-title">Requester Risk</h3>
          </div>
        </div>
        <p class="module-text">Capital deployed without deterministic delivery guarantees. Zero technical enforcement.</p>
        <div class="module-stats">
          <div class="m-stat">
            <span class="m-val">67%</span>
            <span class="m-lab">DELAY_FACTOR</span>
          </div>
          <div class="m-stat">
            <span class="m-val">$2.3B</span>
            <span class="m-lab">CAPITAL_LEAK</span>
          </div>
        </div>
      </div>

      <!-- Symmetrical Center Divider -->
      <div class="matrix-divider">
        <div class="divider-dot top"></div>
        <div class="divider-line"></div>
        <div class="divider-center">VS</div>
        <div class="divider-line"></div>
        <div class="divider-dot bottom"></div>
      </div>

      <!-- Provider Side -->
      <div class="risk-module provider">
        <div class="module-header">
          <div class="module-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div class="module-info">
            <span class="module-id">SOURCE_B</span>
            <h3 class="module-title">Provider Risk</h3>
          </div>
        </div>
        <p class="module-text">Output delivery decoupled from settlement. Counterparty default remains the default state.</p>
        <div class="module-stats">
          <div class="m-stat">
            <span class="m-val">43%</span>
            <span class="m-lab">PAY_LATENCY</span>
          </div>
          <div class="m-stat">
            <span class="m-val">89D</span>
            <span class="m-lab">COLLECT_CYC</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- impact -->
    <div class="system-impact">
      <div class="impact-inner">
        <span class="impact-tag">SYSTEM_FAILURE_RESULT</span>
        <h3 class="impact-title">The Broken Trust Economy</h3>
        <p class="impact-text">
          Traditional workflows are built on fragile social trust. SkillRail replaces this with mathematical finality.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-problem-refined {
    position: relative;
    padding: 5rem 0; /* Compacted from 6rem/8rem */
    background: #0F172A;
    overflow: hidden;
  }

  .relative-z { position: relative; z-index: 10; }

  /* ============================================
     BACKGROUND (MAINTAINED)
     ============================================ */
  
  .sr-problem-refined__bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: 0;
  }
  
  .bg-gradient {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: 
      radial-gradient(circle at 30% 20%, rgba(245, 158, 11, 0.15) 0%, transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(239, 68, 68, 0.1) 0%, transparent 50%);
    animation: warningGlow 4s ease-in-out infinite alternate;
  }
  
  .bg-pattern {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: linear-gradient(rgba(245, 158, 11, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(245, 158, 11, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    opacity: 0.3;
  }

  .warning-particle {
    position: absolute;
    width: 4px; height: 4px;
    background: #F59E0B;
    border-radius: 50%;
    animation: warningFloat 8s ease-in-out infinite;
  }
  .particle-1 { top: 20%; left: 10%; }
  .particle-2 { top: 70%; left: 25%; }
  .particle-3 { top: 40%; right: 20%; }
  .particle-4 { top: 80%; right: 30%; }

  /* ============================================
     HEADER
     ============================================ */

  .section-header { text-align: center; margin-bottom: 3rem; } /* Compacted */

  .tech-badge {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.2);
    color: #F59E0B;
    font-family: var(--font-family-mono);
    font-size: 0.65rem;
    font-weight: 700;
    margin-bottom: 1rem; /* Compacted */
  }

  .headline {
    font-size: 3rem; /* Compacted from 3.5rem */
    font-weight: 900;
    color: white;
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem; /* Compacted */
  }

  .description {
    font-size: 1.1rem;
    color: #94A3B8;
    max-width: 600px;
    margin: 0 auto;
  }

  /* ============================================
     SYMMETRICAL MATRIX
     ============================================ */

  .risk-matrix {
    display: grid;
    grid-template-columns: 1fr 100px 1fr;
    gap: 0;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto 3rem; /* Compacted */
  }

  .risk-module {
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2rem; /* Compacted from 2.5rem */
    border-radius: 4px;
    transition: all 0.3s ease;
  }

  .risk-module:hover {
    background: rgba(30, 41, 59, 0.8);
    border-color: rgba(245, 158, 11, 0.2);
    transform: translateY(-4px);
  }

  .module-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem; } /* Compacted */
  .module-icon { color: #F59E0B; }
  .module-id { font-family: var(--font-family-mono); font-size: 0.6rem; color: #475569; font-weight: 800; }
  .module-title { font-size: 1.25rem; font-weight: 800; color: white; }

  .module-text { font-size: 0.9rem; color: #94A3B8; line-height: 1.5; margin-bottom: 2rem; } /* Compacted */

  .module-stats { display: flex; gap: 2rem; }
  .m-stat { display: flex; flex-direction: column; gap: 0.25rem; }
  .m-val { font-family: var(--font-family-mono); font-size: 1.15rem; font-weight: 800; color: white; }
  .m-lab { font-family: var(--font-family-mono); font-size: 0.55rem; color: #F59E0B; font-weight: 700; }

  /* DIVIDER */

  .matrix-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    height: 100%;
  }

  .divider-line { width: 1px; flex: 1; background: rgba(255, 255, 255, 0.05); }
  .divider-center { font-family: var(--font-family-mono); font-size: 0.7rem; font-weight: 900; color: #334155; }
  .divider-dot { width: 4px; height: 4px; background: #334155; border-radius: 50%; }

  /* IMPACT */

  .system-impact {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 3rem; /* Compacted from 5rem */
  }

  .impact-tag { font-family: var(--font-family-mono); font-size: 0.6rem; color: #EF4444; font-weight: 800; margin-bottom: 1rem; display: block; }
  .impact-title { font-size: 1.5rem; font-weight: 900; color: white; margin-bottom: 0.75rem; }
  .impact-text { font-size: 0.95rem; color: #94A3B8; line-height: 1.5; }

  @keyframes warningGlow { from { opacity: 0.7; } to { opacity: 1; } }
  @keyframes warningFloat { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

  @media (max-width: 1024px) {
    .risk-matrix { grid-template-columns: 1fr; gap: 2rem; }
    .matrix-divider { flex-direction: row; height: auto; justify-content: center; margin-bottom: 2rem; }
    .divider-line { height: 1px; width: 60px; }
  }
</style>
