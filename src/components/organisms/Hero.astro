---
/**
 * Hero Section - Revolutionary Design
 * 
 * DESIGN PHILOSOPHY: "Bold Innovation"
 * - Dramatic gradient backgrounds with animated elements
 * - Large, impactful typography with visual hierarchy
 * - Interactive floating elements and particles
 * - Modern glassmorphism effects
 * - Animated statistics and call-to-actions
 */

const heroHeadline = "SkillRail";
const heroSubheadline = "The Future of Automated Work Settlement";
const heroDescription = "Revolutionary protocol for modern work formats, utilizing advanced blockchain technology to automate the coordination, execution, and settlement of digital tasks and AI agent workflows.";
---

<section class="sr-hero">
  <!-- Animated Background Elements -->
  <div class="sr-hero__bg-container">
    <div class="sr-hero__gradient-bg"></div>
    <div class="sr-hero__particles">
      <div class="particle particle-1"></div>
      <div class="particle particle-2"></div>
      <div class="particle particle-3"></div>
      <div class="particle particle-4"></div>
      <div class="particle particle-5"></div>
      <div class="particle particle-6"></div>
    </div>
    <div class="sr-hero__grid-overlay"></div>
  </div>
  
  <div class="container">
    <div class="sr-hero__content">
      <!-- Protocol Badge with Glow -->
      <div class="sr-hero__badge">
        <div class="badge-glow"></div>
        <span class="badge-text">SOLANA PROTOCOL</span>
      </div>
      
      <!-- Main Headline with Gradient Text -->
      <h1 class="sr-hero__headline">
        <span class="headline-main">{heroHeadline}</span>
        <span class="headline-sub">{heroSubheadline}</span>
      </h1>
      
      <!-- Description -->
      <p class="sr-hero__description">
        {heroDescription}
      </p>
      
      <!-- Protocol Status Bar (Refined Stats) -->
      <div class="sr-hero__status-bar">
        <div class="status-item">
          <span class="status-label">AUTOMATION:</span>
          <span class="status-value">AUTONOMOUS_AGENT_RAILS</span>
        </div>
        <div class="status-divider"></div>
        <div class="status-item">
          <span class="status-label">CUSTODY:</span>
          <span class="status-value">ISOLATED_PDA_VAULTS</span>
        </div>
        <div class="status-divider"></div>
        <div class="status-item">
          <span class="status-label">RUNTIME:</span>
          <span class="status-value">AGENT_READY_SDK</span>
        </div>
      </div>
      
      <!-- Enhanced CTA Buttons -->
      <div class="sr-hero__cta">
        <a href="/explore" class="btn-primary">
          <span class="btn-text">Explore Protocol</span>
          <div class="btn-glow"></div>
          <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/docs" class="btn-secondary">
          <span class="btn-text">View Documentation</span>
          <svg class="btn-icon" width="20" height="20" viewBox="0 0 24 24" fill="none">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2"/>
            <polyline points="14,2 14,8 20,8" stroke="currentColor" stroke-width="2"/>
          </svg>
        </a>
      </div>
      
    </div>
  </div>
</section>

<style>
  /* ============================================
     HERO SECTION - Revolutionary Design
     ============================================ */
  
  .sr-hero {
    position: relative;
    min-height: 85vh; /* Reduced from 100vh for tighter feel */
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(135deg, #0F172A 0%, #1E293B 50%, #334155 100%);
    padding-top: 6rem; /* Space for FloatingNav */
    padding-bottom: 4rem;
    will-change: transform;
  }
  
  /* ============================================
     ANIMATED BACKGROUND SYSTEM
     ============================================ */
  
  .sr-hero__bg-container {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
  }
  
  .sr-hero__gradient-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: 
      radial-gradient(circle at 20% 80%, rgba(99, 102, 241, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(16, 185, 129, 0.2) 0%, transparent 50%),
      radial-gradient(circle at 40% 40%, rgba(245, 158, 11, 0.1) 0%, transparent 50%);
    animation: gradientShift 8s ease-in-out infinite;
  }
  
  .sr-hero__particles {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }
  
  .particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: rgba(99, 102, 241, 0.6);
    border-radius: 50%;
    animation: float 6s ease-in-out infinite;
  }
  
  .particle-1 { top: 20%; left: 10%; animation-delay: 0s; }
  .particle-2 { top: 60%; left: 20%; animation-delay: 1s; background: rgba(16, 185, 129, 0.6); }
  .particle-3 { top: 30%; left: 80%; animation-delay: 2s; }
  .particle-4 { top: 80%; left: 70%; animation-delay: 3s; background: rgba(245, 158, 11, 0.6); }
  .particle-5 { top: 10%; left: 60%; animation-delay: 4s; }
  .particle-6 { top: 70%; left: 90%; animation-delay: 5s; background: rgba(16, 185, 129, 0.6); }
  
  .sr-hero__grid-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      linear-gradient(rgba(99, 102, 241, 0.1) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 102, 241, 0.1) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.3;
    animation: gridPulse 4s ease-in-out infinite;
  }
  
  /* ============================================
     CONTENT STYLING
     ============================================ */
  
  .sr-hero__content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem;
  }
  
  /* Protocol Badge */
  .sr-hero__badge {
    position: relative;
    display: inline-block;
    margin-bottom: 2rem;
    animation: slideInDown 1s ease-out;
  }
  
  .badge-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-indigo);
    border-radius: 50px;
    opacity: 0.1;
    filter: blur(20px);
    z-index: -1;
  }

  .badge-text {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.03) 100%);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 2px;
    color: #ffffff;
    font-weight: 700;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    font-family: var(--font-family-mono);
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3), inset 0 1px 1px rgba(255, 255, 255, 0.1);
    position: relative;
    overflow: hidden;
  }

  .badge-text::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 50%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    animation: sweep 4s infinite;
  }

  @keyframes sweep {
    0% { left: -100%; }
    20% { left: 200%; }
    100% { left: 200%; }
  }

  /* Main Headline */
  .sr-hero__headline {
    margin-bottom: 3rem;
    animation: slideInUp 1s ease-out 0.2s both;
  }

  .headline-main {
    display: block;
    font-size: 7rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.05em;
    line-height: 0.85;
    margin-bottom: 1.5rem;
    background: linear-gradient(to bottom, #ffffff 40%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    /* Metallic/Glass effect that feels high-end and unique */
  }
  
  .headline-sub {
    display: block;
    font-size: 2rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.3;
  }
  
  /* Description */
  .sr-hero__description {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    animation: slideInUp 1s ease-out 0.4s both;
  }
  
  /* Protocol Status Bar */
  .sr-hero__status-bar {
    display: inline-flex;
    align-items: center;
    gap: 2rem;
    padding: 0.5rem 1.5rem;
    background: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    margin-bottom: 4rem;
    animation: slideInUp 1s ease-out 0.6s both;
  }

  .status-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .status-label {
    font-family: var(--font-family-mono);
    font-size: 0.6rem;
    font-weight: 800;
    color: #475569;
    letter-spacing: 0.1em;
  }

  .status-value {
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: #10B981; /* Emerald Success */
  }

  .status-divider {
    width: 1px;
    height: 24px;
    background: rgba(255, 255, 255, 0.1);
  }
  
  /* Enhanced Buttons */
  .sr-hero__cta {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 4rem;
    animation: slideInUp 1s ease-out 0.8s both;
  }
  
  .btn-primary, .btn-secondary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1.25rem 2.5rem;
    border-radius: 50px;
    font-size: 1.1rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    overflow: hidden;
    z-index: 1;
  }
  
  .btn-primary {
    background: linear-gradient(135deg, #6366F1 0%, #4F46E5 100%);
    color: white;
    border: none;
    box-shadow: 0 10px 30px rgba(99, 102, 241, 0.4);
  }
  
  .btn-primary:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(99, 102, 241, 0.6);
  }
  
  .btn-secondary {
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
  }
  
  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-5px);
  }
  
  .btn-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, #6366F1, #10B981);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: -1;
  }
  
  .btn-primary:hover .btn-glow {
    opacity: 0.2;
  }
  
  .btn-text {
    position: relative;
    z-index: 2;
  }
  
  .btn-icon {
    transition: transform 0.3s ease;
  }
  
  .btn-primary:hover .btn-icon,
  .btn-secondary:hover .btn-icon {
    transform: translateX(5px);
  }
  
  /* Floating Elements */
  .sr-hero__floating-elements {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
  }
  
  .floating-element {
    position: absolute;
    width: 60px;
    height: 60px;
    animation: floatAround 8s ease-in-out infinite;
  }
  
  .element-inner {
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    animation: rotate 6s linear infinite;
  }
  
  .element-1 { top: 20%; left: 15%; animation-delay: 0s; }
  .element-2 { top: 60%; right: 15%; animation-delay: 2s; }
  .element-3 { bottom: 20%; left: 20%; animation-delay: 4s; }
  
  /* ============================================
     ANIMATIONS
     ============================================ */
  
  @keyframes gradientShift {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; }
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(180deg); }
  }
  
  @keyframes gridPulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.1; }
  }
  
  @keyframes slideInDown {
    from { opacity: 0; transform: translateY(-50px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes slideInUp {
    from { opacity: 0; transform: translateY(50px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  @keyframes textGlow {
    0% { filter: brightness(1); }
    100% { filter: brightness(1.2); }
  }
  
  @keyframes countUp {
    from { opacity: 0; transform: scale(0.5); }
    to { opacity: 1; transform: scale(1); }
  }
  
  @keyframes rotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  
  @keyframes floatAround {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    25% { transform: translate(20px, -20px) rotate(90deg); }
    50% { transform: translate(-10px, -30px) rotate(180deg); }
    75% { transform: translate(-20px, 10px) rotate(270deg); }
  }
  
  /* ============================================
     RESPONSIVE DESIGN
     ============================================ */
  
  @media (max-width: 768px) {
    .sr-hero {
      min-height: auto; /* Allow natural height on mobile */
      padding: 4rem 0 2rem; /* Give space at top for Nav */
    }
    
    .headline-main {
      font-size: 3rem;
    }
    
    .headline-sub {
      font-size: 1.5rem;
    }
    
    .sr-hero__description {
      font-size: 1.1rem;
      margin-bottom: 2.5rem;
    }
    
    .sr-hero__status-bar {
      display: none !important;
    }
    
    .sr-hero__cta {
      flex-direction: column;
      align-items: center;
    }
    
    .btn-primary, .btn-secondary {
      width: 100%;
      max-width: 300px;
      justify-content: center;
    }
    
    .floating-element {
      display: none;
    }
  }
  
  /* ============================================
     ACCESSIBILITY
     ============================================ */
  
  @media (prefers-reduced-motion: reduce) {
    * {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>