---
/**
 * Hero Section - Enterprise-Grade
 * 
 * DESIGN PHILOSOPHY: "Institutional Authority"
 * - Centered, commanding layout
 * - Large, bold headline with product name
 * - Professional subheadline with clear value prop
 * - Credibility markers (protocol badge)
 * - Background: Subtle grid pattern (suggests structure, not decoration)
 */

const heroHeadline = "SkillRail: Funding, Fulfilling, and Settling Outsourced Asynchronous Digital Work on Solana.";
const heroSubheadline = "Transforming delayed work into programmable, trustless transactions for human and agent-driven workflows.";
---

<section class="sr-hero">
  <div class="sr-hero__background"></div>
  
  <div class="container">
    <div class="sr-hero__content">
      <h1 class="sr-hero__headline">
        {heroHeadline}
      </h1>
      
      <p class="sr-hero__subheadline">
        {heroSubheadline}
      </p>
      
      <div class="sr-hero__cta">
        <a href="#explore" class="sr-button sr-button--primary">
          Explore the Protocol
        </a>
        <a href="#docs" class="sr-button sr-button--secondary">
          Read Documentation
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* ============================================
     HERO SECTION - Container & Layout
     ============================================ */
  
  .sr-hero {
    position: relative;
    padding: 9rem var(--section-padding-horizontal) 8rem;
    background-color: var(--color-bg-primary);
    overflow: hidden;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  /* Subtle grid background pattern - suggests structure */
  .sr-hero__background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: 
      linear-gradient(90deg, var(--color-slate-200) 1px, transparent 1px),
      linear-gradient(0deg, var(--color-slate-200) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.3;
    pointer-events: none;
  }
  
  .sr-hero__content {
    position: relative;
    z-index: 1;
    max-width: 950px;
    margin: 0 auto;
    text-align: center;
  }
  
  /* ============================================
     HEADLINE - Protocol Voice (Tight, Precise)
     ============================================ */
  
  .sr-hero__headline {
    font-size: 3.75rem;
    font-weight: var(--font-weight-bold);
    line-height: 1.15;
    letter-spacing: -0.025em;
    color: var(--color-navy);
    margin-bottom: var(--space-3xl);
    max-width: 950px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeInUp 0.8s ease-out;
  }
  
  /* ============================================
     SUBHEADLINE - Human Voice (Readable, Warm)
     ============================================ */
  
  .sr-hero__subheadline {
    font-size: 1.375rem;
    font-weight: var(--font-weight-regular);
    line-height: 1.8;
    letter-spacing: 0.2px;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4xl);
    max-width: 850px;
    margin-left: auto;
    margin-right: auto;
    animation: fadeInUp 0.8s ease-out 0.1s both;
  }
  
  /* ============================================
     CTA BUTTONS - Secondary Focus
     ============================================ */
  
  .sr-hero__cta {
    display: flex;
    gap: var(--space-lg);
    flex-wrap: wrap;
    justify-content: center;
    animation: fadeInUp 0.8s ease-out 0.2s both;
  }
  
  /* ============================================
     BUTTON STYLES - Reusable
     ============================================ */
  
  .sr-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.125rem 3rem;
    border-radius: var(--radius-md);
    font-size: 1rem;
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
    outline: 2px solid transparent;
    outline-offset: 2px;
    letter-spacing: 0.5px;
  }
  
  .sr-button:focus-visible {
    outline-color: var(--color-indigo);
  }
  
  /* Primary Button - Indigo, Filled */
  .sr-button--primary {
    background-color: var(--color-indigo);
    color: white;
    box-shadow: 0 12px 32px rgba(99, 102, 241, 0.25);
  }
  
  .sr-button--primary:hover {
    background-color: var(--color-indigo-dark);
    box-shadow: 0 24px 48px rgba(99, 102, 241, 0.4);
    transform: translateY(-4px);
  }
  
  .sr-button--primary:active {
    transform: translateY(-2px);
  }
  
  /* Secondary Button - Indigo, Outline */
  .sr-button--secondary {
    background-color: transparent;
    color: var(--color-indigo);
    border: 1.5px solid var(--color-indigo);
  }
  
  .sr-button--secondary:hover {
    background-color: var(--color-indigo);
    color: white;
    box-shadow: 0 12px 32px rgba(99, 102, 241, 0.25);
    transform: translateY(-4px);
  }
  
  .sr-button--secondary:active {
    transform: translateY(-2px);
  }
  
  /* ============================================
     ANIMATIONS
     ============================================ */
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  /* ============================================
     RESPONSIVE DESIGN
     ============================================ */
  
  @media (max-width: 768px) {
    .sr-hero {
      padding: 5.5rem var(--section-padding-horizontal-mobile) 4.5rem;
      min-height: auto;
    }
    
    .sr-hero__headline {
      font-size: 2.25rem;
      margin-bottom: var(--space-2xl);
      line-height: 1.25;
    }
    
    .sr-hero__subheadline {
      font-size: 1.125rem;
      line-height: 1.7;
      margin-bottom: var(--space-3xl);
    }
    
    .sr-hero__cta {
      flex-direction: column;
      gap: var(--space-md);
    }
    
    .sr-button {
      width: 100%;
      padding: 1rem 2rem;
      font-size: 0.9375rem;
    }
  }
  
  /* ============================================
     ACCESSIBILITY - Reduced Motion
     ============================================ */
  
  @media (prefers-reduced-motion: reduce) {
    .sr-hero__headline,
    .sr-hero__subheadline,
    .sr-hero__cta {
      animation: none;
    }
    
    .sr-button {
      transition: none;
    }
    
    .sr-button:hover {
      transform: none;
    }
  }
</style>
