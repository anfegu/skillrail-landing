---
/**
 * Call To Action Section - Professional Design Refinement
 * 
 * IMPROVES THE ORIGINAL DESIGN:
 * - Keeps exact original text and structure.
 * - Enhances visual depth with a sophisticated indigo gradient system.
 * - Refines typography hierarchy and button fidelity.
 */
---

<section id="join" class="sr-cta">
  <div class="sr-cta__visual-base"></div>
  
  <div class="container relative-z">
    <div class="sr-cta__content">
      <h2 class="sr-cta__headline">Ready to Transform Async Work?</h2>
      <p class="sr-cta__description">
        Deploy your workflows on the SkillRail protocol. Automate the coordination and settlement of digital tasks for humans and AI agents.
      </p>
      
      <div class="sr-cta__buttons">
        <a href="/explore" class="sr-cta__btn sr-cta__btn--primary">
          <span>Explore Protocol</span>
          <div class="btn-hover-effect"></div>
        </a>
        <a href="/docs" class="sr-cta__btn sr-cta__btn--secondary">
          Technical Specs
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-cta {
    position: relative;
    padding: 10rem 0;
    background-color: var(--color-indigo); /* Flat Brand Purple */
    background-image: none !important;
    text-align: center;
    overflow: hidden;
  }

  /* Subtle innovative background texture */
  .sr-cta__visual-base {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.3;
  }

  .sr-cta::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 120%;
    height: 120%;
    background: radial-gradient(circle at center, rgba(16, 185, 129, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  .relative-z {
    position: relative;
    z-index: 10;
  }

  .sr-cta__content {
    max-width: 800px;
    margin: 0 auto;
  }

  .sr-cta__headline {
    font-size: 4rem;
    font-weight: 800;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    text-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .sr-cta__description {
    font-size: 1.25rem;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
    max-width: 600px;
    margin: 0 auto 4rem;
  }

  .sr-cta__buttons {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .sr-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem 3rem;
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 200ms ease-out;
    position: relative;
    overflow: hidden;
  }

  .sr-cta__btn--primary {
    background-color: white;
    background-image: none !important;
    color: var(--color-indigo);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15);
  }

  .sr-cta__btn--primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
    background-color: #F8FAFC;
  }

  .sr-cta__btn--secondary {
    background-color: rgba(255, 255, 255, 0.1);
    color: white;
    border: 2px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
  }

  .sr-cta__btn--secondary:hover {
    background-color: rgba(255, 255, 255, 0.2);
    border-color: white;
    transform: translateY(-3px);
  }

  @media (max-width: 768px) {
    .sr-cta {
      padding: 6rem 0;
    }
    
    .sr-cta__headline {
      font-size: 2.5rem;
    }
    
    .sr-cta__buttons {
      flex-direction: column;
      align-items: center;
    }
    
    .sr-cta__btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
