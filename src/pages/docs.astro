---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/organisms/Footer.astro";

const pageTitle = "The SkillRail Bible | Technical Specifications";
const pageDescription = "Definitive technical documentation for the SkillRail work settlement protocol on Solana. Architecture, State Machine, Account Layouts, and SDK specifications.";

const chapters = [
  {
    id: "architecture",
    title: "1. Core Architecture",
    sections: [
      {
        h: "Design Philosophy",
        p: "SkillRail is an institutional-grade settlement standard designed to eliminate the 'Trust Tax' in labor markets. It uses a Clean Architecture pattern, isolating pure business rules (Domain) from platform-specific infrastructure."
      },
      {
        h: "Key Principles",
        list: [
          "Deterministic Finality: On-chain state transitions govern the entire job lifecycle.",
          "Universal Agnosticism: Behavioral parity across Docker, Mac, and Linux environments.",
          "Non-Custodial Security: PDAs act as sovereign vaults, ensuring assets are protected by cryptographic logic."
        ]
      },
      {
        h: "System Integrity",
        list: [
          "Instruction-Logic Separation: lib.rs delegates to logic.rs for pure rule validation.",
          "Isolated Vaults: Each job uses a program-controlled vault for asset separation.",
          "Strict Account Checks: Deterministic PDA verification for every mutation."
        ]
      }
    ]
  },
  {
    id: "state-machine",
    title: "2. The Work State Machine",
    sections: [
      {
        h: "Lifecycle Transitions",
        p: "The protocol enforces a strict directional flow to ensure contract compliance.",
        table: [
          ["Source State", "Target State", "Authorized Actor", "Outcome"],
          ["None", "Created", "Requester", "Terms defined on-chain"],
          ["Created", "Funded", "Requester", "Assets locked in vault"],
          ["Funded", "Submitted", "Provider", "Result metadata reference stored"],
          ["Submitted", "Completed", "Requester", "Atomically settled & paid"],
          ["Funded", "Refunded", "Requester", "Recovery after deadline expiry"]
        ]
      },
      {
        h: "Invariant Rules",
        list: [
          "Jobs must be 'Funded' before work submission.",
          "Payouts are atomic and requires requester acceptance.",
          "Refunds only trigger after deadline + Funded status."
        ]
      }
    ]
  },
  {
    id: "accounts",
    title: "3. Account Memory Layout",
    sections: [
      {
        h: "ProviderProfile (253 Bytes)",
        p: "Stores technical identity and reputation markers.",
        table: [
          ["Field", "Type", "Bytes", "Description"],
          ["authority", "Pubkey", "32", "The provider's wallet"],
          ["metadata_uri", "String", "204", "Identity payload (Max 200 chars)"],
          ["created_at", "i64", "8", "Timestamp"],
          ["bump", "u8", "1", "PDA derivation bump"]
        ]
      },
      {
        h: "Job (547 Bytes)",
        p: "The authoritative record of a work settlement contract.",
        table: [
          ["Field", "Type", "Bytes", "Description"],
          ["requester", "Pubkey", "32", "Funding party"],
          ["provider", "Pubkey", "32", "Executing party"],
          ["mint", "Pubkey", "32", "Settlement asset (e.g. USDC)"],
          ["amount", "u64", "8", "Escrow volume"],
          ["status", "Enum", "1", "Current machine state"],
          ["deadline_at", "i64", "8", "Expiry timestamp"],
          ["terms_uri", "String", "204", "Agreement reference"],
          ["result_uri", "String", "204", "Delivery reference"]
        ]
      },
      {
        h: "Sizing Strategy",
        p: "All string fields are strictly bounded to ensuring predictable account rent costs. Metadata URIs (metadata, terms, result) are limited to 200 characters each."
      }
    ]
  },
  {
    id: "instructions",
    title: "4. Instruction Specification",
    sections: [
      {
        h: "register_provider",
        p: "Initializes a provider profile. Precondition: metadata_uri.len() <= 200 bytes.",
        table: [
          ["Account", "Type", "Signer"],
          ["provider", "Signer", "Yes"],
          ["profile", "PDA", "No"],
          ["system_program", "Program", "No"]
        ]
      },
      {
        h: "create_job",
        p: "Initializes a Job PDA. Requires: valid assigned provider profile, amount > 0, and future deadline.",
        table: [
          ["Input", "Type", "Notes"],
          ["job_id", "u64", "Unique per requester"],
          ["amount", "u64", "Base units"],
          ["deadline_at", "i64", "Unix timestamp"]
        ]
      },
      {
        h: "fund_job",
        p: "Escrows assets from Requester to Job Vault. Atomic CPI transfer ensures status only moves to 'Funded' on success."
      },
      {
        h: "submit_result",
        p: "Provider commits work. Valid only if Funded and before deadline."
      },
      {
        h: "accept_result",
        p: "Requester finalizes the job. Triggers atomic payout from Vault to Provider."
      },
      {
        h: "refund_job",
        p: "Recovery path. Valid only if Funded and Clock > deadline_at."
      },
      {
        h: "Technical Table",
        table: [
          ["Instruction", "Signer", "State Change"],
          ["register_provider", "Provider", "Init Profile"],
          ["create_job", "Requester", "Init PDA"],
          ["fund_job", "Requester", "Lock Assets"],
          ["submit_result", "Provider", "Link Result"],
          ["accept_result", "Requester", "Payout"],
          ["refund_job", "Requester", "Recover"]
        ]
      }
    ]
  },
  {
    id: "sdk",
    title: "5. SDK & Integration Layer",
    sections: [
      {
        h: "SkillRailClient",
        p: "The high-level entry point for all frontends and services. Encapsulates RPC complexity, PDA derivation, and transaction building."
      },
      {
        h: "Domain Entities",
        p: "Rich objects like 'JobEntity' provide off-chain utility methods (isFunded, canRequesterRefund) ensuring business logic remains consistent."
      },
      {
        h: "Code Snippet",
        p: "const client = new SkillRailClient(program); const job = await client.getJob(address);"
      }
    ]
  },
  {
    id: "network",
    title: "6. Multi-Network Strategy",
    sections: [
      {
        h: "Transition Matrix",
        table: [
          ["Cluster", "RPC Endpoint", "Official USDC Mint"],
          ["Localhost", "http://localhost:8899", "Dynamic (via setup)"],
          ["Devnet", "https://api.devnet.solana.com", "4zMMC9srt5Ri5TQJEUveajzQXWvDvcNth7S4V9BXXm6N"],
          ["Mainnet", "https://api.mainnet-beta.solana.com", "EPjFW36vS7ox6re7FLUvHA7L6z5HKu39wjLzerjhcLhH"]
        ]
      }
    ]
  },
  {
    id: "validation",
    title: "7. Protocol Validation Logic",
    sections: [
      {
        h: "Strict Security Checks",
        p: "The protocol centralizes security logic into dedicated validation modules to prevent bypass attacks.",
        list: [
          "ACCOUNT_OWNERSHIP: Verified via Anchor's #[account] macros.",
          "SIGNATURE_AUTHORITY: Every mutation requires a multi-signer proof.",
          "TOKEN_MINT_ENFORCEMENT: Only authorized settlement assets are accepted.",
          "PDA_CANONICAL_CHECK: Bumps are validated to prevent account spoofing."
        ]
      }
    ]
  },
  {
    id: "repository",
    title: "8. Technical Repository Map",
    sections: [
      {
        h: "Monorepo Structure",
        p: "SkillRail follows a unified monorepo pattern for behavioral parity across layers.",
        list: [
          "/contracts: Authoritative Rust source of truth.",
          "/sdk: TypeScript bridge for RPC orchestration.",
          "/web: Next.js operator dashboard.",
          "/tests: High-assurance protocol test suite."
        ]
      }
    ]
  },
  {
    id: "security-deep-dive",
    title: "9. Protocol Security Model",
    sections: [
      {
        h: "High-Assurance Integrity",
        p: "SkillRail enforces security through deterministic isolation.",
        list: [
          "Isolated Vaults: Each job uses a unique PDA-controlled ATA.",
          "Canonical Verification: Forced bump validation prevents spoofing.",
          "Signer Constraints: Multi-party verification for every state jump."
        ]
      }
    ]
  },
  {
    id: "system-governance",
    title: "10. System Design & DDD",
    sections: [
      {
        h: "Architectural Philosophy",
        p: "Built on Domain-Driven Design (DDD) to isolate business invariants from blockchain infrastructure.",
        list: [
          "Pure Domain Logic: Rust modules for pure transition rules.",
          "Agnostic SDK: Repository patterns for RPC orchestration.",
          "Operator Dashboard: Feature-sliced presentation layer."
        ]
      }
    ]
  },
  {
    id: "error-codes",
    title: "11. Global Error Registry",
    sections: [
      {
        h: "Program Exceptions",
        p: "Authoritative reference for on-chain error codes.",
        table: [
          ["Code", "Description", "Resolution"],
          ["InvalidDeadline", "Timestamp in past", "Use future unix time"],
          ["DeadlineExceeded", "Work submitted late", "Refund path active"],
          ["UriTooLong", "Metadata > 200B", "Compress metadata string"]
        ]
      }
    ]
  }
];
---

<Layout title={pageTitle} description={pageDescription}>
  <nav class="sr-bible-nav">
    <div class="container">
      <div class="sr-bible-nav__left">
        <a href="/" class="sr-bible-nav__logo">SkillRail</a>
        <span class="sr-bible-nav__divider">/</span>
        <span class="sr-bible-nav__current">PROTOCOL_BIBLE</span>
      </div>
      <a href="/" class="sr-bible-nav__back">← Back to Portal</a>
    </div>
  </nav>

  <div class="sr-bible-layout">
    <aside id="bible-mobile-drawer" class="sr-bible-sidebar">
      <nav class="sr-bible-toc">
        <div class="sr-bible-toc__label">DOC_STRUCTURE</div>
        <ul class="sr-bible-toc__list">
          {chapters.map(chapter => (
            <li><a href={`#${chapter.id}`} class="sr-bible-toc__link bible-nav-link">{chapter.title}</a></li>
          ))}
        </ul>
      </nav>
    </aside>

    <main class="sr-bible-content">
      <div class="sr-bible-hero">
        <h1 class="sr-bible-hero__title">Institutional Settlement Specification</h1>
        <p class="sr-bible-hero__description">
          The definitive technical standard for the SkillRail work settlement protocol. This document is the source of truth for the system's architecture and logic.
        </p>
      </div>

      {chapters.map((chapter) => (
        <section id={chapter.id} class="sr-bible-chapter">
          <h2 class="sr-bible-chapter__title">{chapter.title}</h2>
          <div class="sr-bible-chapter__body">
            {chapter.sections.map((section) => (
              <div class="sr-bible-section">
                <h3 class="sr-bible-section__heading">{section.h}</h3>
                {section.p && <p class="sr-bible-section__text">{section.p}</p>}
                
                {section.list && (
                  <ul class="sr-bible-section__list">
                    {section.list.map(item => (
                      <li class="sr-bible-section__list-item">{item}</li>
                    ))}
                  </ul>
                )}

                {section.steps && (
                  <div class="sr-bible-section__steps">
                    {section.steps.map((step, idx) => (
                      <div class="step-card">
                        <span class="step-number">{idx + 1}</span>
                        <span class="step-text">{step}</span>
                      </div>
                    ))}
                  </div>
                )}

                {section.table && (
                  <div class="sr-bible-section__table-wrapper">
                    <table class="sr-bible-section__table">
                      <thead>
                        <tr>
                          {section.table[0].map(cell => <th>{cell}</th>)}
                        </tr>
                      </thead>
                      <tbody>
                        {section.table.slice(1).map(row => (
                          <tr>
                            {row.map(cell => <td>{cell}</td>)}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            ))}
          </div>
        </section>
      ))}
    </main>
  </div>

  <div class="sr-bible-footer-anchor">
    <div class="sr-mobile-structure-trigger" id="mobile-toc-trigger">
      <span class="trigger-icon"></span>
      <span class="trigger-text">DOC_STRUCT</span>
    </div>
    <Footer />
  </div>
</Layout>

<script>
  // Innovative Mobile TOC logic
  const trigger = document.getElementById('mobile-toc-trigger');
  const drawer = document.getElementById('bible-mobile-drawer');
  const links = document.querySelectorAll('.bible-nav-link');
  const sections = document.querySelectorAll('.sr-bible-chapter');

  trigger?.addEventListener('click', () => {
    drawer?.classList.toggle('mobile-active');
    trigger?.classList.toggle('trigger-active');
  });

  links.forEach(link => {
    link.addEventListener('click', () => {
      drawer?.classList.remove('mobile-active');
      trigger?.classList.remove('trigger-active');
    });
  });

  function updateActiveSection() {
    let activeId = '';
    const scrollPosition = window.scrollY + 120;

    sections.forEach(section => {
      const top = (section as HTMLElement).offsetTop;
      const height = (section as HTMLElement).offsetHeight;
      const id = section.getAttribute('id');
      
      if (scrollPosition >= top && scrollPosition < top + height) {
        activeId = id || '';
      }
    });

    links.forEach(link => {
      link.classList.remove('active-section');
      if (link.getAttribute('href') === `#${activeId}`) {
        link.classList.add('active-section');
      }
    });
  }

  window.addEventListener('scroll', updateActiveSection);
  window.addEventListener('load', updateActiveSection);
  links.forEach(l => l.addEventListener('click', () => setTimeout(updateActiveSection, 100)));
</script>

<style>
  /* ============================================
     BIBLE PAGE - Technical, High-Assurance Look
     ============================================ */

  .sr-bible-nav {
    padding: 1.25rem 0;
    background-color: var(--color-navy);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .sr-bible-nav .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .sr-bible-nav__left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sr-bible-nav__logo {
    font-weight: 900;
    color: white;
    font-size: 1.125rem;
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .sr-bible-nav__divider {
    color: rgba(255, 255, 255, 0.2);
    font-family: var(--font-family-mono);
  }

  .sr-bible-nav__current {
    font-family: var(--font-family-mono);
    color: var(--color-indigo-light);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
  }

  .sr-bible-nav__back {
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .sr-bible-nav__back:hover {
    color: white;
  }

  .sr-bible-layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* ============================================
     SIDEBAR NAVIGATION
     ============================================ */

  .sr-bible-sidebar {
    background-color: #f8fafc;
    border-right: 1px solid var(--color-border);
    height: calc(100vh - 64px);
    position: sticky;
    top: 64px;
    padding: 3rem 2rem;
    overflow-y: auto;
  }

  .sr-bible-toc__label {
    font-family: var(--font-family-mono);
    font-size: 0.7rem;
    color: var(--color-slate-400);
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
  }

  .sr-bible-toc__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sr-bible-toc__link {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-slate-600);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .sr-bible-toc__link:hover {
    color: var(--color-indigo);
    transform: translateX(4px);
  }

  .sr-bible-toc__link.active-section {
    color: var(--color-indigo) !important;
    padding-left: 0.75rem !important;
    border-left: 2px solid var(--color-indigo) !important;
    font-weight: 700 !important;
    background: rgba(99, 102, 241, 0.05);
  }

  .sr-mobile-structure-trigger {
    display: none;
  }

  .sr-bible-footer-anchor {
    position: sticky;
    bottom: 0;
    z-index: 2100;
  }

  /* ============================================
     CONTENT AREA
     ============================================ */

  .sr-bible-content {
    padding: 4rem 6rem;
    background-color: white;
    position: relative;
  }

  .sr-bible-hero {
    margin-bottom: 6rem;
    border-bottom: 2px solid var(--color-navy);
    padding-bottom: 3rem;
  }

  .sr-bible-hero__title {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--color-navy);
    letter-spacing: -0.03em;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .sr-bible-hero__description {
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    max-width: 800px;
    line-height: 1.6;
  }

  .sr-bible-chapter {
    margin-bottom: 6rem;
    scroll-margin-top: 100px;
  }

  .sr-bible-chapter__title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-navy);
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .sr-bible-chapter__title::after {
    content: "";
    flex-grow: 1;
    height: 1px;
    background-color: var(--color-border);
  }

  .sr-bible-section {
    margin-bottom: 4rem;
  }

  .sr-bible-section__heading {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 1.25rem;
    font-family: var(--font-family-mono);
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .sr-bible-section__heading::before {
    content: ">>";
    color: var(--color-indigo);
  }

  .sr-bible-section__text {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .sr-bible-section__list {
    list-style: none;
    padding-left: 1.5rem;
  }

  .sr-bible-section__list-item {
    position: relative;
    padding-bottom: 0.75rem;
    color: var(--color-text-secondary);
    font-size: 1.0625rem;
  }

  .sr-bible-section__list-item::before {
    content: "•";
    position: absolute;
    left: -1.5rem;
    color: var(--color-indigo);
    font-weight: bold;
  }

  /* Steps Styling */
  .sr-bible-section__steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem 0;
  }

  .step-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 2rem;
    background-color: #f8fafc;
    border: 1px solid var(--color-border);
    border-radius: 12px;
  }

  .step-number {
    width: 2rem;
    height: 2rem;
    background-color: var(--color-navy);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: 900;
    font-family: var(--font-family-mono);
    flex-shrink: 0;
  }

  .step-text {
    font-weight: 600;
    color: var(--color-navy);
  }

  /* Table Styling */
  .sr-bible-section__table-wrapper {
    overflow-x: auto;
    margin: 2rem 0;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
  }

  .sr-bible-section__table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    text-align: left;
  }

  .sr-bible-section__table th {
    background: var(--color-navy);
    padding: 1.25rem 1.5rem;
    color: white;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
  }

  .sr-bible-section__table td {
    padding: 1.25rem 1.5rem;
    color: var(--color-text-secondary);
    border-bottom: 1px solid var(--color-border);
    word-break: break-word;
  }

  .sr-bible-section__table tr:last-child td {
    border-bottom: none;
  }

  .sr-bible-section__table tr:hover td {
    background-color: #f8fafc;
  }

  @media (max-width: 1024px) {
    .sr-bible-layout {
      grid-template-columns: 1fr;
    }
    
    /* Innovative Mobile Drawer */
    .sr-bible-sidebar {
      position: fixed;
      left: 0;
      top: 0;
      bottom: 0;
      width: 280px;
      z-index: 2000;
      background: var(--color-navy);
      border-right: 2px solid var(--color-indigo);
      transform: translateX(-100%);
      transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      display: block !important;
      padding: 2rem 1.5rem;
    }

    .sr-bible-sidebar.mobile-active {
      transform: translateX(0);
    }

    .sr-bible-toc__link {
      color: rgba(255, 255, 255, 0.7);
    }

    .sr-bible-toc__label {
      color: var(--color-indigo-light);
    }

    .sr-bible-content {
      padding: 3rem 1.5rem;
    }
    
    .sr-bible-hero__title {
      font-size: 2.25rem;
    }

    /* "Architect of Certainty" Mobile Trigger - Refined v2 */
    .sr-mobile-structure-trigger {
      display: flex;
      position: fixed;
      bottom: 6rem; /* Clear of footer */
      right: 1.5rem;
      z-index: 3000;
      background: #ffffff;
      color: var(--color-navy);
      padding: 0.8rem 1.2rem;
      border-radius: 2px;
      font-family: var(--font-family-mono);
      font-size: 0.65rem;
      font-weight: 900;
      gap: 0.75rem;
      align-items: center;
      border: 2px solid var(--color-navy);
      box-shadow: 6px 6px 0px var(--color-indigo); 
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
      letter-spacing: 0.15em;
      white-space: nowrap;
    }

    /* Stays lifted and sophisticated when opened */
    .sr-mobile-structure-trigger.trigger-active {
      background: var(--color-navy);
      color: #ffffff;
      border-color: var(--color-indigo);
      box-shadow: 6px 6px 0px var(--color-indigo-light);
      transform: translateY(-8px); /* Lifts even more to show active state */
    }

    .sr-mobile-structure-trigger::before {
      content: '●';
      font-size: 0.5rem;
      color: var(--color-indigo);
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.8); }
      100% { opacity: 1; transform: scale(1); }
    }

    .sr-mobile-structure-trigger:active {
      transform: translate(2px, 2px);
      box-shadow: 2px 2px 0px var(--color-indigo);
    }

    .trigger-icon {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .sr-bible-nav {
      padding: 0.75rem 0;
    }

    .sr-bible-nav .container {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .sr-bible-nav__left {
