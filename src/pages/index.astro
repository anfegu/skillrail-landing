---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/organisms/Hero.astro";
import Problem from "../components/organisms/Problem.astro";
import Solution from "../components/organisms/Solution.astro";
import HowItWorks from "../components/organisms/HowItWorks.astro";
import Features from "../components/organisms/Features.astro";
import CallToAction from "../components/molecules/CallToAction.astro";
import Footer from "../components/organisms/Footer.astro";

const pageTitle = "SkillRail: Solana-Native Settlement Protocol for Async Work";
const pageDescription = "SkillRail is a Solana-native protocol for funding, fulfilling, and settling outsourced asynchronous work. It transforms delayed digital work into a programmable transaction flow.";
---

<Layout title={pageTitle} description={pageDescription}>
  <main>
    <Hero />
    <Problem />
    <Solution />
    <HowItWorks />
    <Features />
    <CallToAction />
  </main>
  <Footer />
</Layout>
