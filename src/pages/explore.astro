---
import Layout from "../layouts/Layout.astro";
import Exploration from "../components/organisms/Exploration.astro";

const pageTitle = "Protocol Exploration Lab | SkillRail";
const pageDescription = "Explore the on-chain settlement transitions and cryptographic state of the SkillRail protocol.";
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="sr-explore-wrapper">
    <nav class="sr-explore-nav">
      <div class="container">
        <a href="/" class="sr-explore-nav__logo">SkillRail</a>
        <a href="/" class="sr-explore-nav__back">← Back to Portal</a>
      </div>
    </nav>

    <main class="sr-explore-main">
      <Exploration />
    </main>
  </div>
</Layout>

<style>
  .sr-explore-nav {
    padding: 1.5rem 0;
    background-color: var(--color-bg-secondary);
    border-bottom: 1px solid var(--color-border);
  }

  .sr-explore-nav .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .sr-explore-nav__logo {
    font-weight: var(--font-weight-bold);
    color: var(--color-navy);
    font-size: 1.25rem;
    letter-spacing: -0.01em;
  }

  .sr-explore-nav__back {
    color: var(--color-indigo);
    font-family: var(--font-family-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color var(--transition-fast);
  }

  .sr-explore-nav__back:hover {
    color: var(--color-navy);
  }

  .sr-explore-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 80vh;
    min-height: 80dvh;
    background-color: var(--color-bg-secondary);
  }

  .sr-explore-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 0;
  }

  /* Mobile-specific fix to keep Nav visible during scroll */
  @media (max-width: 768px) {
    .sr-explore-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1001;
      background-color: var(--color-bg-secondary);
    }

    .sr-explore-wrapper {
      padding-top: 5rem; /* Nav height approximation */
      min-height: 100vh;
      min-height: 100dvh;
    }

    .sr-explore-main {
      justify-content: flex-start; /* Better for scrolling content on mobile */
      padding-top: 1rem;
    }
  }
</style>
