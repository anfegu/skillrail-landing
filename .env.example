# SkillRail Environment Variables (Landing Page)
# Configure these in your Vercel Project Settings or local .env file

# Technical Links
PUBLIC_SOLANA_EXPLORER_URL=https://explorer.solana.com
PUBLIC_GITHUB_URL=https://github.com/

# Social Links
PUBLIC_X_URL=https://x.com/skillrail
PUBLIC_DISCORD_URL=https://discord.gg/skillrail

# Navigation
PUBLIC_DOCS_URL=/docs

# ============================================
# Protocol Status & States
# ============================================

# System Status Indicator (Footer)
# Consistent States: 
# - UNDER_DEVELOPMENT (Active building phase)
# - MAINTENANCE (Updates in progress)
# - OPERATIONAL (Normal operation)
# - DEGRADED (Performance issues)
PUBLIC_SYS_STATUS=UNDER_DEVELOPMENT

# Solution Matrix Development Phase (Solution Section)
# Consistent States:
# - DEVELOPMENT_ACTIVE (Foundational Building - Slate)
# - PHASE_01_INITIALIZATION (Systematic Setup - Indigo)
# - PHASE_02_VALIDATION (Testing/Verification - Amber)
# - SETTLEMENT_READY (Completed/Finality - Emerald)
PUBLIC_SOLUTION_STATUS=DEVELOPMENT_ACTIVE
